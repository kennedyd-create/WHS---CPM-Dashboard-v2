          --pe-bg: #FFEDED;
          --pe-text: #BF0000;
          --maori-bg: #ECFBFF;
          --maori-text: #1A6ABE;
          --social-bg: #F5EFFF;
          --social-text: #7900CC;
        }

        /* Set the main container background */
        .whs-container {
          background-color: var(--whs-accent);
          min-height: 100vh;
          display: flex;
          flex-direction: column;
        }

        /* Header as dark banner */
        .whs-header {
          background-color: var(--whs-primary);
          color: #ffffff; /* White text for accessibility */
          padding: 2rem;
          display: flex;
          align-items: center;
          justify-content: space-between;
          border-bottom: 2px solid #ffffff;
        }

        /* Make the header title card much larger and panoramic to reduce dead space */
        .whs-header-card {
          background-color: var(--whs-light); /* Keep light field */
          border-radius: 12px;
          padding: 1rem 1.5rem; /* Reduced padding slightly to fill card */
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          border: 1px solid var(--whs-text); /* Add WHS Dark Blue border */
          display: flex;
          align-items: center;
          gap: 1.5rem;
          cursor: pointer;
          transition: background-color 0.2s, box-shadow 0.2s;
        }
        
        .whs-logo-frame {
          /* Frame around the logo image to make it seen better */
          display: flex;
          align-items: center;
          justify-content: center;
          background-color: #ffffff; /* White field for logo for high contrast */
          border-radius: 8px;
          padding: 0.5rem;
          width: 100px; /* Define fixed sizes */
          height: 100px;
          box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
        }

        .whs-logo {
          width: auto;
          height: 100%; /* Fill frame height */
          display: block; /* Ensure no image spacing bugs */
        }

        .whs-title-group {
          /* Text group remains, but title text will be larger */
        }

        .whs-h1 {
          font-family: var(--whs-font-main);
          font-weight: 700;
          font-size: 2rem; /* Larger title text to fill space */
          color: var(--whs-text);
          margin-bottom: 0.25rem;
        }

        .whs-subtitle {
          color: var(--whs-text);
          opacity: 0.8;
          font-size: 1.1rem;
        }

        .whs-error-card {
          background-color: #ffffff;
          padding: 0.5rem 1rem;
          border-radius: 8px;
          color: #dc2626;
          font-weight: bold;
        }

        .whs-nav-card {
          background-color: #ffffff;
          border-radius: 12px;
          padding: 0.25rem;
          display: flex;
          gap: 0.25rem;
          box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
        }

        .whs-nav-item {
          background: none;
          border: none;
          color: var(--whs-text);
          padding: 0.75rem 1.5rem;
          font-family: var(--whs-font-main);
          font-weight: 600;
          font-size: 1rem;
          border-radius: 10px;
          cursor: pointer;
          transition: background-color 0.2s, color 0.2s;
        }

        .whs-nav-item:hover {
          background-color: var(--whs-accent);
        }

        .whs-nav-item.active {
          background-color: var(--whs-primary);
          color: #ffffff;
        }
      </style>
    </div>
